#!/bin/bash

# 1. Strict Root Enforcement
if [ "$EUID" -ne 0 ]; then
  echo "[!] Error: Sentry touches secured vaults. Please run as root (sudo sentry enroll)"
  exit 1
fi

APP_DIR="/opt/sentry"
PYTHON_BIN="$APP_DIR/.venv/bin/python3"
ENROLL_SCRIPT="$APP_DIR/src/enroll.py"

if [[ "$1" == "enroll" ]]; then
    echo "[*] Launching Biometric Enrollment..."
    
    if "$PYTHON_BIN" "$ENROLL_SCRIPT"; then
    
        if systemctl list-unit-files sentry.service > /dev/null 2>&1; then
            echo "[*] Reloading Sentry Daemon with new baseline..."
            systemctl restart sentry.service
            echo "[SUCCESS] System updated."
        else
            echo "[*] Baseline saved. Service will be registered shortly."
        fi
        
    else
        echo "[-] Enrollment failed or aborted."
        exit 1
    fi
else
    echo "Sentry Biometric Daemon"
    echo "Usage: sudo sentry enroll"
    exit 1
fi