#!/bin/bash

APP_DIR="/opt/faceauth"
PYTHON_BIN="$APP_DIR/.venv/bin/python3"
ENROLL_SCRIPT="$APP_DIR/src/enroll.py"

if [[ "$1" == "enroll" ]]; then
    echo "[*] Launching Biometric Enrollment..."
    
    if "$PYTHON_BIN" "$ENROLL_SCRIPT"; then
        
        # Safely check if the systemd service actually exists before restarting it
        # This prevents the race condition during initial installation
        if systemctl list-unit-files faceauth.service > /dev/null 2>&1; then
            echo "[*] Reloading Sentry Daemon with new baseline..."
            systemctl restart faceauth.service
            echo "[SUCCESS] System updated."
        else
            echo "[*] Baseline saved. Service will be registered shortly."
        fi
        
    else
        echo "[-] Enrollment failed or aborted."
        exit 1
    fi
else
    echo "Face Authentication Sentry"
    echo "Usage: faceauth enroll"
    exit 1
fi